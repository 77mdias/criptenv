{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "lint": "eslint",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "e2e:db:up": "docker compose -f ../../docker-compose.e2e.yml up -d postgres-e2e",
    "e2e:db:reset": "cd ../api && if [ -x .venv/bin/python ]; then .venv/bin/python scripts/reset_e2e_db.py; else python scripts/reset_e2e_db.py; fi",
    "e2e:api": "cd ../api && if [ -x .venv/bin/python ]; then .venv/bin/python scripts/run_e2e_api.py; else python scripts/run_e2e_api.py; fi",
    "e2e:web": "node scripts/run-e2e-web.mjs",
    "test:e2e": "npm run e2e:db:up && npm run e2e:db:reset && concurrently -k -s first -n api,web,cypress -c blue,green,magenta \"npm run e2e:api\" \"npm run e2e:web\" \"wait-on tcp:127.0.0.1:8000 tcp:localhost:3000 && env -u ELECTRON_RUN_AS_NODE cypress run\"",
    "test:e2e:open": "npm run e2e:db:up && npm run e2e:db:reset && concurrently -k -n api,web,cypress -c blue,green,magenta \"npm run e2e:api\" \"npm run e2e:web\" \"wait-on tcp:127.0.0.1:8000 tcp:localhost:3000 && env -u ELECTRON_RUN_AS_NODE cypress open\"",
    "check:vinext": "vinext check",
    "deploy": "vinext deploy",
    "deploy:dry-run": "vinext deploy --dry-run",
    "dev:next": "next dev",
    "build:next": "next build",
    "start:next": "next start",
    "dev:vinext": "vinext dev --port 3001",
    "build:vinext": "vinext build",
    "start:vinext": "vinext start"
  },
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "pagefind": "^1.5.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.26",
    "concurrently": "^9.2.1",
    "cypress": "^15.14.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react-server-dom-webpack": "^19.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vinext": "^0.0.45",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "postcss": "^8.5.12"
  },
  "type": "module"
}
