# ===========================================
# CriptEnv Web - Environment Variables
# ===========================================

# Browser API URL. Leave empty in Cloudflare Pages production so requests use
# the same-origin Worker proxy at /api/*.
NEXT_PUBLIC_API_URL=

# Cloudflare Worker runtime binding, set in Pages environment variables.
API_URL=https://criptenv-api.77mdevseven.tech

# Session cookie name (must match API config)
NEXT_PUBLIC_COOKIE_NAME=criptenv_session

# Frontend URL
NEXT_PUBLIC_APP_URL=https://criptenv.77mdevseven.tech
