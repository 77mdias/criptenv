# ===========================================
# CriptEnv Web - Environment Variables
# ===========================================

# Backend API URL (your Render web service URL or custom domain)
NEXT_PUBLIC_API_URL=https://api.criptenv.com

# Session cookie name (must match API config)
NEXT_PUBLIC_COOKIE_NAME=criptenv_session

# Frontend URL
NEXT_PUBLIC_APP_URL=https://criptenv.com
