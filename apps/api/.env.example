# ===========================================
# Criptenv - Environment Variables
# ===========================================

# ===========================================
# DATABASE (Supabase PostgreSQL)
# ===========================================
# Get this from Supabase Dashboard → Settings → Database → Connection String
# Use the Pooler connection string (port 6543) for serverless environments
# Format: postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@host:5432/db
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=10

# Optional: direct connection for migrations (port 5432)
# DIRECT_URL=postgresql://postgres:password@host:5432/db

# ===========================================
# SECURITY
# ===========================================
SECRET_KEY=your-secret-key-min-32-chars-change-in-production
INTEGRATION_CONFIG_SECRET=your-random-integration-config-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SESSION_EXPIRE_DAYS=30

# ===========================================
# APP CONFIG
# ===========================================
DEBUG=false
APP_ENV=production
CORS_ORIGINS=https://criptenv.77mdevseven.tech

# ===========================================
# RATE LIMITING
# ===========================================
# Use memory locally. Use redis in VPS/multi-worker production.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=memory
# REDIS_URL=redis://redis:6379/0

# ===========================================
# API / FRONTEND URLS
# ===========================================
# API URL for OAuth callbacks and webhooks
API_URL=https://criptenv-api.77mdevseven.tech

# Frontend URL for OAuth redirect after callback
FRONTEND_URL=https://criptenv.77mdevseven.tech

# ===========================================
# MERCADO PAGO (CONTRIBUTIONS / PAYMENTS)
# ===========================================
MERCADO_PAGO_ACCESS_TOKEN=TEST-...
MERCADO_PAGO_PUBLIC_KEY=TEST-...
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_BASE_URL=https://api.mercadopago.com
PAYMENTS_ENABLED=true
PAYMENTS_ENV=sandbox

# ===========================================
# OAUTH PROVIDERS (optional — only if using social login)
# ===========================================
# GitHub OAuth - https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Discord OAuth - https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# ===========================================
# BACKGROUND JOBS
# ===========================================
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_HOURS=24
