# ===========================================
# CriptEnv API - VPS Production Environment
# Copy this file to deploy/vps/.env on the VPS and replace every placeholder.
# ===========================================

# ===========================================
# PUBLIC URLS
# ===========================================
API_DUCKDNS_HOST=criptenv.duckdns.org
API_URL=https://criptenv.duckdns.org

# Use the exact Cloudflare Workers/Pages frontend URL. Do not use a wildcard here.
FRONTEND_URL=https://criptenv.jean-carlos3.workers.dev
CORS_ORIGINS=https://criptenv.jean-carlos3.workers.dev

# ===========================================
# DATABASE - SUPABASE POSTGRESQL
# ===========================================
# Prefer the Supabase pooler URL on port 6543.
DATABASE_URL=postgresql://postgres.project:password@aws-0-region.pooler.supabase.com:6543/postgres
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=10

# ===========================================
# SECURITY
# ===========================================
SECRET_KEY=replace-with-a-random-64-character-secret
INTEGRATION_CONFIG_SECRET=replace-with-a-different-random-64-character-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SESSION_EXPIRE_DAYS=30
DEBUG=false
APP_ENV=production

# ===========================================
# GUNICORN / UVICORN
# ===========================================
WEB_CONCURRENCY=3
API_LOCAL_PORT=8000

# ===========================================
# REDIS RATE LIMITING
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=redis
REDIS_URL=redis://redis:6379/0

# ===========================================
# BACKGROUND JOBS
# ===========================================
# In deploy/vps/docker-compose.yml the public api service overrides this to false
# and the scheduler service overrides it to true.
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_HOURS=24

# ===========================================
# DUCKDNS
# ===========================================
DUCKDNS_SUBDOMAIN=criptenv
DUCKDNS_TOKEN=replace-with-your-duckdns-token
DUCKDNS_UPDATE_SECONDS=300

# ===========================================
# NGINX PROXY MANAGER
# ===========================================
# Keep the admin UI private. Access it with:
# ssh -L 8181:127.0.0.1:81 root@YOUR_VPS_IP
NPM_ADMIN_BIND=127.0.0.1

# ===========================================
# OAUTH PROVIDERS (optional)
# ===========================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
