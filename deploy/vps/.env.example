# ===========================================
# CriptEnv API on VPS
# Copy to deploy/vps/.env and fill secrets on the server.
# ===========================================

# Public API hostname managed by DuckDNS and Nginx Proxy Manager.
API_DUCKDNS_HOST=criptenv.duckdns.org
API_URL=https://criptenv.duckdns.org

# Cloudflare Pages frontend URL. Keep browser API requests relative and set
# Cloudflare Pages runtime API_URL to the public API URL above.
FRONTEND_URL=https://criptenv.jean-carlos3.workers.dev
CORS_ORIGINS=https://criptenv.jean-carlos3.workers.dev

# Supabase PostgreSQL. Prefer the pooler URL on port 6543.
DATABASE_URL=postgresql://postgres.project:password@aws-0-region.pooler.supabase.com:6543/postgres
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=10

# Security
SECRET_KEY=change-me-to-a-random-64-character-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SESSION_EXPIRE_DAYS=30
DEBUG=false
APP_ENV=production

# Gunicorn/Uvicorn workers for the public API service.
WEB_CONCURRENCY=3
API_LOCAL_PORT=8000

# Redis-backed rate limiting. Redis is only used for operational counters.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=redis
REDIS_URL=redis://redis:6379/0

# Background jobs run in the dedicated scheduler service, not in public workers.
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_HOURS=24

# DuckDNS updater. DUCKDNS_SUBDOMAIN is the part before .duckdns.org.
DUCKDNS_SUBDOMAIN=criptenv
DUCKDNS_TOKEN=change-me
DUCKDNS_UPDATE_SECONDS=300

# Nginx Proxy Manager admin UI. Keep this bound to localhost unless firewalled.
NPM_ADMIN_BIND=127.0.0.1

# OAuth providers (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
