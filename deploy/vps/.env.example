# ===========================================
# CriptEnv API on VPS
# Copy to deploy/vps/.env and fill secrets on the server.
# ===========================================


# ===========================================
# PUBLIC URLS
# ===========================================
# Public API URL routed through Cloudflare Tunnel.
API_URL=https://criptenv-api.77mdevseven.tech

# Use the exact Cloudflare Pages custom frontend URL. Do not use a wildcard here.
FRONTEND_URL=https://criptenv.77mdevseven.tech
CORS_ORIGINS=https://criptenv.77mdevseven.tech


# ===========================================
# DATABASE - SUPABASE POSTGRESQL
# ===========================================
# Prefer the Supabase pooler URL on port 6543.
# Supabase PostgreSQL. Prefer the pooler URL on port 6543.
DATABASE_URL=postgresql://postgres.project:password@aws-0-region.pooler.supabase.com:6543/postgres
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=10


# ===========================================
# SECURITY
# ===========================================
SECRET_KEY=change-me-to-a-random-64-character-secret
INTEGRATION_CONFIG_SECRET=change-me-to-a-different-random-64-character-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SESSION_EXPIRE_DAYS=30
DEBUG=false
APP_ENV=production


# ===========================================
# GUNICORN / UVICORN
# ===========================================
# Gunicorn/Uvicorn workers for the public API service.
WEB_CONCURRENCY=3
API_LOCAL_PORT=8000


# ===========================================
# REDIS RATE LIMITING
# ===========================================
# Redis-backed rate limiting. Redis is only used for operational counters.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=redis
REDIS_URL=redis://redis:6379/0


# ===========================================
# BACKGROUND JOBS
# ===========================================
# In deploy/vps/docker-compose.yml the public api service overrides this to false
# and the scheduler service overrides it to true.
# Background jobs run in the dedicated scheduler service, not in public workers.
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_HOURS=24

# ==========================================
# CLOUDFLARE TUNNEL
# ==========================================
# Cloudflare Zero Trust tunnel token that routes
# https://criptenv-api.77mdevseven.tech -> http://api:8000.
TUNNEL_TOKEN=change-me


# ===========================================
# MERCADO PAGO (CONTRIBUTIONS / PAYMENTS)
# ===========================================
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
MERCADO_PAGO_PUBLIC_KEY=APP_USR-...
MERCADO_PAGO_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_WEBHOOK_SECRET=...
PAYMENTS_PROVIDER=mercadopago
PAYMENTS_ENABLED=true

# ===========================================
# OAUTH PROVIDERS (optional)
# ===========================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=


# ===========================================
# DOCKER REGISTRY
# ===========================================
# Docker Hub username/org for pulling images.
# Watchtower will auto-update when new images are pushed.
DOCKER_REGISTRY=77mdias
CRIPTENV_VERSION=latest

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx  # sua chave do Resend
EMAIL_FROM=admin@77mdevseven.tech               # ou onboarding@resend.dev para testes